<?xml version="1.0" encoding="utf-8"?>
<worlds>

  <world Name="JoppaWorld" Load="Merge">
    <cell Name="Sibs_Garden_RubberOrchard" Inherits="DefaultJoppaCell" ApplyTo="Sibs_Garden_TerrainRubberOrchard">
      <zone Level="5-9" x="0-2" y="0-2" Name="sky above the rubber orchard" IndefiniteArticle="the" AmbientBed="Sounds/Ambiences/amb_bed_deepJungle">
        <builder Class="Sky"></builder>
      </zone>
      <zone Level="10" x="0-2" y="0-2" Name="rubber orchard" HasWeather="true" WindSpeed="0-60" WindDirections="N,NW,NW,W,W,SW,S,SE" WindDuration="50-3000" AmbientBed="Sounds/Ambiences/amb_bed_deepJungle">
        <postbuilder Class="ZoneTemplate:Sibs_Garden_RubberOrchard"></postbuilder>
        <builder Class="JungleRuins" Chance="5"></builder>
        <builder Class="FactionEncounters" Population="GenericFactionPopulation"></builder>
        <music Track="Music/lostgarden/overgrowth.mp3" />
      </zone>
      <zone Level="11-15" x="0-2" y="0-2" Name="subterranean rubber orchard">
        <builder Class="Strata"></builder>
        <builder Class="ZoneTemplate:JungleCaves"></builder>
        <builder Class="PossibleCryotube"></builder>
        <builder Class="FactionEncounters" Population="GenericFactionPopulation"></builder>
        <music Track="Music/lostgarden/undergrowth.mp3" />
      </zone>
    </cell>
	
    <cell Name="Sibs_Garden_LostGarden" Inherits="Sibs_Garden_RubberOrchard" ApplyTo="Sibs_Garden_TerrainLostGarden" Mutable="false">
	
      <!-- Lost Garden Surface-->
		<zone Level="10" x="1" y="1" Name="lost garden" ProperName="true" IncludeStratumInZoneDisplay="false" DisableForcedConnections="Yes" HasWeather="true" WindSpeed="0-60" WindDirections="W,SW,S,SE" WindDuration="50-3000">
			<map FileName="Sibs_GardenSurface.rpm"></map>
			<music Track="Music/lostgarden/overgrowth.mp3" />
			<builder Class="PulldownLocation" x="31" y="24"></builder>
		</zone>
	  
	  	<zone Level="11" x="1" y="1" Name="undergarden" DisableForcedConnections="Yes">
			<map FileName="Sibs_Garden1.rpm" />
			<music Track="Music/lostgarden/undergrowth.mp3" />
		</zone>

	  	<zone Level="12" x="1" y="1" Name="undergarden" DisableForcedConnections="Yes">
			<map FileName="Sibs_Garden2.rpm" />
			<music Track="Music/lostgarden/undergrowth.mp3" />
		</zone>

	  	<zone Level="13" x="1" y="1" Name="undergarden" DisableForcedConnections="Yes">
			<map FileName="Sibs_Garden3.rpm" />
			<music Track="Music/lostgarden/undergrowth.mp3" />
		</zone>
		
    </cell>
	

	
	
	
	
  </world>
</worlds>