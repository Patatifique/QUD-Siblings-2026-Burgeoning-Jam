<?xml version="1.0" encoding="utf-8" ?>
<zonetemplates>
  
    <zonetemplate Name="Rubber Orchard" RegionSize="200">
        <global>      
        <population Table="RubberOrchardZoneGlobals-Surface" Hint="Any"></population>
        <cellfilterout Filter="!Reachable">
            <population Table="RubberOrchardZoneGlobals-Reachable"></population>
        </cellfilterout>
        </global>

        <eachregion>
        <group Criteria="Connection">
            <exit/>
        </group>
        <population Table="RubberOrchardPerSector"></population>
        </eachregion>
    </zonetemplate>

</zonetemplates>